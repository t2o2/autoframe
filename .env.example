# ── Linear ───────────────────────────────────────────────────────────────────
# API key from Linear → Settings → API → Personal API keys
LINEAR_API_KEY=lin_api_your_key_here

# Team key from Linear → Settings → Team → Team key (e.g. ENG, ACME, GYL)
LINEAR_TEAM_KEY=ENG

# ── API credentials ───────────────────────────────────────────────────────────
#
# Option A — Claude.ai subscription (default, no API cost)
#   Leave both keys empty. The container forwards your host OAuth session
#   from ~/.claude/credentials.json — no extra setup required.
#
# Option B — OpenRouter (fallback; billed per token)
#   Get from: https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=
# Models for each tier. Find model IDs at openrouter.ai/models
OR_MODEL_NORMAL=deepseek/deepseek-v4-pro
OR_MODEL_ADVANCED=deepseek/deepseek-v4-pro
#
# Option C — Anthropic direct API key
#   Get from: https://console.anthropic.com/settings/api-keys
ANTHROPIC_API_KEY=

# ── Git ───────────────────────────────────────────────────────────────────────
# Repository the container will clone and work in.
GIT_REPO_URL=https://github.com/your-org/your-repo.git

# Branch to clone from (default: develop).
GIT_BASE_BRANCH=develop

# GitHub personal access token for HTTPS cloning and pushing.
# Needs: repo (read + write), workflow (if pushing CI changes).
# Leave blank if using SSH — mount ~/.ssh instead (see docker-compose.yml).
GITHUB_TOKEN=ghp_your_token_here

# ── Docker platform ───────────────────────────────────────────────────────────
# linux/arm64 for Apple Silicon (M1/M2/M3), linux/amd64 for Intel/AMD
DOCKER_PLATFORM=arm64
DOCKER_TARGETARCH=arm64

# ── Spec-feedback loop (spec-loop / spec-loop-pi profiles) ────────────────────
# Change-driven audit agent: polls GIT_BASE_BRANCH and, when new commits land,
# blind-describes the affected spec-map areas, compares against the docs/ spec
# corpus, and files divergences as Linear Backlog tickets — intraday, minutes
# after a merge. All values optional — defaults shown.
# The ONLY project-specific input is docs/spec-map.yaml in the target repo.
# A repo without one makes this agent idle — so the same autoframe image plugs
# into any project. The runner + agent defs are bundled and seeded automatically.
#SPEC_LOOP_POLL_INTERVAL_S=300  # seconds between branch polls (300 = 5 min)
#SPEC_LOOP_AREAS=               # force these areas on every audited change (empty = audit only changed areas)
#SPEC_LOOP_PUSH_REPORTS=0       # 1 = also bot-commit docs/reviews/** back to GIT_BASE_BRANCH (default: tickets only)
#SPEC_LOOP_COMMIT_PREFIX=       # prefix for the report commit msg to satisfy a commit-msg hook, e.g. "GYL-440: "
